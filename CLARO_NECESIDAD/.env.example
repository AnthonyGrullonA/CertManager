# =============================================================================
# CertManager — .env de PRODUCCIÓN (plantilla)
#
# Copia este archivo a CLARO_NECESIDAD/.env y completa los valores marcados.
# El .env real NO se versiona (está en .gitignore): contiene secretos.
# Lo cargan los scripts de instalación (install_server.sh / install_docker.sh).
# =============================================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.prod
# Genera con:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=<GENERAR-SECRET-KEY>
ALLOWED_HOSTS=certmanager.claro.com.do
CSRF_TRUSTED_ORIGINS=https://certmanager.claro.com.do

# --- Base de datos MySQL (EXTERNA — solicitar a Claro) ---
# Valores POR SEPARADO (no DATABASE_URL).
DB_NAME=certmanager
DB_USER=certmanager
DB_PASSWORD=<CLAVE-BD>
DB_HOST=<HOST-MYSQL>
DB_PORT=3306

# --- TLS / seguridad (detrás de NGINX que termina TLS) ---
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000

# --- Correo SMTP (déjalo vacío si lo configuras desde el panel) ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=certificados@claro.com.do

# --- Logs ---
LOG_DIR=/var/log/certmanager

# --- Observabilidad (opcional; obsforge vive en índice privado de Claro) ---
OBSFORGE_ENABLED=0
# OBSFORGE_LOKI_PRESET=prod

# --- Bootstrap (data_update_certs_app.sh): Owner + config + certificados ---
CF_OWNER_EMAIL=jairol_grullon@claro.com.do
CF_OWNER_PASSWORD=<DEFINIR-CONTRASEÑA-OWNER>
# CF_ORG_NAME=Claro
# CF_CERT_SOURCE=cert.txt
# CF_RUN_CHECK=0

# --- SMTP del bootstrap (opcional; mismos del panel Correo) ---
# CF_SMTP_HOST=
# CF_SMTP_PORT=587
# CF_SMTP_USER=
# CF_SMTP_PASSWORD=
# CF_SMTP_FROM=certificados@claro.com.do
# CF_SMTP_USE_TLS=1
