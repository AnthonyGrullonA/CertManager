# Copia este archivo a .env y completa los valores. NO subir .env al repo.

# --- Django ---
DJANGO_SECRET_KEY=cambia-esta-clave-por-una-larga-y-aleatoria
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.local
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=America/Santo_Domingo

# --- Base de datos ---
# Local (SQLite): dejar comentado usa db.sqlite3 por defecto.
# DATABASE_URL=sqlite:///db.sqlite3
# Producción (MySQL/PostgreSQL):
# DATABASE_URL=mysql://usuario:clave@host:3306/certmanager
# DATABASE_URL=postgres://usuario:clave@host:5432/certmanager

# --- Email / SMTP (también configurable en la UI: Configuración → Correo) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=certmanager@localhost

# --- Seguridad ---
# CSP en modo enforce por defecto; pon 1 para volver a solo-reporte (diagnóstico).
CSP_REPORT_ONLY=0
# Bloqueo de login por fuerza bruta (OWASP A07).
LOGIN_LOCKOUT_MAX=5
LOGIN_LOCKOUT_WINDOW=300
LOGIN_LOCKOUT_DURATION=900

# --- Monitoreo ---
MONITORING_THRESHOLD_DAYS=45
MONITORING_CRITICAL_DAYS=15
MONITORING_TIMEOUT=10
MONITORING_INTERVAL_HOURS=24
# Renegociación TLS legacy: DESACTIVADA por defecto (anti-SSRF). Solo activar
# (True) si un host legacy concreto lo requiere.
MONITORING_LEGACY_RENEG=False

# --- Planificador en-proceso (APScheduler) ---
# Si True, el scheduler (certs + reportes + backup) corre dentro del proceso web.
# En producción podés correrlo aparte con `python manage.py run_scheduler`.
RUN_SCHEDULER=False
SCHEDULER_CERT_HOURS=24
SCHEDULER_REPORTS_MINUTES=60
SCHEDULER_BACKUP_HOURS=24
ALERT_RENOTIFY_DAYS=7

# --- Backups de la base de datos ---
BACKUP_DIR=backups
BACKUP_KEEP=14

# --- Siembra de integraciones (seed_integrations) — secretos SOLO por entorno ---
# Se usan UNA vez al sembrar; nunca se hardcodean en el repo.
CF_SEED_SMTP_HOST=
CF_SEED_SMTP_PORT=587
CF_SEED_SMTP_USER=
CF_SEED_SMTP_PASSWORD=
CF_SEED_SMTP_FROM=
CF_SEED_EMAIL_COPY_ADDRESS=
CF_SEED_DEFAULT_RECIPIENT=
CF_SEED_SMS_FTP_HOST=
CF_SEED_SMS_FTP_USER=
CF_SEED_SMS_FTP_PASSWORD=
CF_SEED_SMS_DEFAULT_NUMBER=

# --- Logging (JSON a stdout + fichero rotado; se sincroniza con obsforge) ---
# Directorio de logs. Por defecto /var/log/certmanager; si no es escribible
# (pod K8s sin permiso, local), degrada a <repo>/logs automáticamente.
LOG_DIR=/var/log/certmanager
DJANGO_LOG_LEVEL=INFO
# obsforge (observabilidad). Si el paquete no está instalado, se ignora.
OBSFORGE_ENABLED=True
# OBSFORGE_LOKI_PRESET=prod
# OTEL_SERVICE_NAME=certmanager
# OBSFORGE_ENVIRONMENT=prod
